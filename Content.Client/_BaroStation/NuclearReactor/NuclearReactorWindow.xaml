<DefaultWindow xmlns="https://spacestation14.io"
               Title="Ядерный реактор"
               MinSize="550 550">
    <BoxContainer Orientation="Vertical" Margin="8 8 8 8" SeparationOverride="4">

        <!-- Статус -->
        <BoxContainer Orientation="Horizontal" HorizontalExpand="True" SeparationOverride="4">
            <Label Text="Статус:" />
            <Label Name="StatusLabel" Text="ВЫКЛЮЧЕН" StyleClasses="LabelSecondaryColor" />
            <Control HorizontalExpand="True" />
            <Button Name="ToggleButton" Text="Включить" />
        </BoxContainer>

        <!-- Информация о стержнях -->
        <BoxContainer Orientation="Horizontal" HorizontalExpand="True">
            <Label Text="Стержней установлено:" />
            <Label Name="RodCountLabel" Text="0 / 4" />
            <Control HorizontalExpand="True" />
            <Label Text="Оптимальная температура:" />
            <Label Name="OptimalTempLabel" Text="0 K" />
        </BoxContainer>

        <!-- Режим работы -->
        <BoxContainer Orientation="Horizontal" HorizontalExpand="True">
            <Label Text="Режим работы:" />
            <Label Name="StateLabel" Text="Нет стержней" />
        </BoxContainer>

        <!-- Температура -->
        <BoxContainer Orientation="Vertical">
            <BoxContainer Orientation="Horizontal" HorizontalExpand="True">
                <Label Text="Температура активной зоны:" />
                <Label Name="TemperatureLabel" Text="293 K" HorizontalAlignment="Right" />
            </BoxContainer>
            <ProgressBar Name="TemperatureBar" MinValue="0" MaxValue="5000" Value="293" />

            <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="0 4">
                <Label Text="Задать температуру (K):" />
                <LineEdit Name="TargetTempInput" Text="500" HorizontalExpand="True" />
                <Button Name="SetTempButton" Text="Установить" />
            </BoxContainer>
        </BoxContainer>

        <!-- Мощность -->
        <BoxContainer Orientation="Horizontal">
            <Label Text="Выработка:" />
            <Label Name="PowerLabel" Text="0 kW" />
            <Control HorizontalExpand="True" />
            <Label Text="Целостность:" />
            <Label Name="IntegrityLabel" Text="100%" />
        </BoxContainer>

        <!-- Слоты -->
        <Label Text="ТВЭЛы (Урановые стержни):" Margin="0 8 0 0" />
        <GridContainer Name="RodsGrid" Columns="4" HorizontalExpand="True" />

        <Label Name="WarningLabel" 
               Text="ВНИМАНИЕ: Реактор без стержней не работает!" 
               StyleClasses="LabelCaution" 
               HorizontalAlignment="Center" 
               Margin="0 10" />
    </BoxContainer>
</DefaultWindow>
